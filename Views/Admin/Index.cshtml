<!-- ══ ACTIVITY HISTORY ═══════════════════════════════════════════ -->
@if (tab == "activityhistory")
{
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <span><i class="bi bi-activity me-2" style="color:var(--brand)"></i>Admin Activity History</span>
            <span class="stat-pill">@Model.AdminActivity.Count entries</span>
        </div>
        @if (!Model.AdminActivity.Any())
        {
            <div class="card-body text-center" style="padding:3rem">
                <i class="bi bi-journal-check" style="font-size:2.5rem;color:var(--muted)"></i>
                <p class="mt-3" style="color:var(--muted)">No admin activity recorded yet.</p>
                <p style="font-size:0.78rem;color:var(--muted)">Activity is recorded once the Portal DB is configured.</p>
            </div>
        }
        else
        {
            <div style="max-height:620px;overflow-y:auto">
                <table class="result-table">
                    <thead><tr><th>Admin</th><th>Action</th><th>Target</th><th>Details</th><th>Performed At</th></tr></thead>
                    <tbody>
                        @foreach (var a in Model.AdminActivity)
                        {
                            <tr>
                                <td><strong>@a.AdminUser</strong></td>
                                <td>
                                    @{
                                        var (actionColor, actionIcon) = a.Action switch
                                        {
                                            var x when x.Contains("Delete") || x.Contains("Reject") => ("var(--danger)", "bi-trash3"),
                                            var x when x.Contains("Add") || x.Contains("Approve") || x.Contains("Grant") => ("var(--success)", "bi-check2-circle"),
                                            _ => ("var(--brand)", "bi-pencil")
                                        };
                                    }
                                    <span style="font-size:0.78rem;color:@actionColor;font-weight:600">
                                        <i class="bi @actionIcon me-1"></i>@a.Action
                                    </span>
                                </td>
                                <td style="font-family:'JetBrains Mono',monospace;font-size:0.73rem;font-weight:600">@a.Target</td>
                                <td style="font-size:0.75rem;color:var(--muted);max-width:350px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="@a.Details">@a.Details</td>
                                <td style="font-size:0.72rem;color:var(--muted);white-space:nowrap">@a.PerformedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function toggleUserPanel(un) {
            var p = document.getElementById('panel-'+un);
            p.style.display = p.style.display === 'none' ? 'block' : 'none';
        }
        function toggleConnPanel(key) {
            var p = document.getElementById('conn-panel-'+key);
            p.style.display = p.style.display === 'none' ? 'block' : 'none';
        }
        function togglePwd(id) {
            var i = document.getElementById(id);
            i.type = i.type === 'password' ? 'text' : 'password';
        }

        function saveUser(un) {
            var form  = new FormData();
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            form.append('username',    un);
            form.append('displayName', document.getElementById('dn-'+un).value);
            form.append('email',       document.getElementById('em-'+un).value);
            var pw = document.getElementById('pw-'+un).value;
            if (pw) form.append('password', pw);

            // Collect permission checkboxes
            var grid = document.getElementById('panel-'+un);
            grid.querySelectorAll('input[type=checkbox]').forEach(function(cb) {
                if (cb.checked) form.append(cb.name, cb.value);
            });
            form.append('__RequestVerificationToken', token);

            fetch('@Url.Action("SaveUserAjax", "Admin")', { method:'POST', body: form })
                .then(r=>r.json())
                .then(d=>{
                    var msg = document.getElementById('save-msg-'+un);
                    msg.style.display = 'block';
                    if (d.ok) {
                        msg.style.color = 'var(--success)';
                        msg.innerHTML = '<i class="bi bi-check2-circle me-1"></i>Saved successfully';
                    } else {
                        msg.style.color = 'var(--danger)';
                        msg.innerHTML = '<i class="bi bi-x-circle me-1"></i>' + (d.error||'Error');
                    }
                    setTimeout(()=>{ msg.style.display='none'; }, 3000);
                });
        }

        function testConn(env, btn) {
            var orig = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Testing…';
            btn.disabled = true;
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            fetch('@Url.Action("TestConnection", "Admin")', {
                method:'POST',
                headers:{'Content-Type':'application/x-www-form-urlencoded'},
                body:'env='+encodeURIComponent(env)+'&__RequestVerificationToken='+encodeURIComponent(token)
            }).then(r=>r.json()).then(d=>{
                btn.disabled = false;
                if (d.ok) {
                    btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>' + d.ms + 'ms';
                    btn.style.color = 'var(--success)';
                } else {
                    btn.innerHTML = '<i class="bi bi-x-circle me-1"></i>Failed';
                    btn.style.color = 'var(--danger)';
                    alert('Connection failed: ' + d.error);
                }
                setTimeout(()=>{ btn.innerHTML=orig; btn.style.color=''; }, 4000);
            });
        }

        function testPortalDb() {
            var btn = document.getElementById('testPdbBtn');
            var orig = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Testing…';
            btn.disabled = true;
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            fetch('@Url.Action("TestPortalDb", "Admin")', {
                method:'POST',
                headers:{'Content-Type':'application/x-www-form-urlencoded'},
                body:'__RequestVerificationToken='+encodeURIComponent(token)
            }).then(r=>r.json()).then(d=>{
                btn.disabled = false;
                if (d.ok) {
                    btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i>' + d.ms + 'ms — Connected';
                    btn.style.borderColor='rgba(34,197,94,0.4)'; btn.style.color='var(--success)';
                } else {
                    btn.innerHTML = '<i class="bi bi-x-circle me-1"></i>Failed';
                    btn.style.color='var(--danger)';
                    alert('Portal DB error: ' + d.error);
                }
                setTimeout(()=>{ btn.innerHTML=orig; btn.style.color=''; btn.style.borderColor=''; }, 5000);
            });
        }
    </script>
}

@* ── FEEDBACK TAB ──────────────────────────────────────────── *@
@if (tab == "feedback")
{
    <div class="card mb-3">
        <div class="card-header"><i class="bi bi-chat-dots-fill me-2" style="color:var(--brand)"></i>User Feedback</div>
        @if (!Model.Feedbacks.Any())
        {
            <div class="card-body text-center text-muted">No feedback submitted yet.</div>
        }
        @foreach (var fb in Model.Feedbacks)
        {
            <div style="padding:1rem;border-bottom:1px solid var(--border)">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div>
                        <strong style="font-size:0.88rem">@fb.Subject</strong>
                        <span class="op-chip @(fb.Status=="Closed"?"allowed":"")" style="margin-left:6px">@fb.Status</span>
                        <div style="font-size:0.75rem;color:var(--muted)">@fb.DisplayName (@fb.Username) · @fb.CreatedAt.ToString("dd-MMM-yyyy HH:mm")</div>
                        <p style="font-size:0.82rem;margin-top:4px;white-space:pre-wrap">@fb.Message</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(fb.AdminReply))
                {
                    <div class="p-2 rounded mb-2" style="background:var(--surface3);font-size:0.8rem"><strong>Admin reply:</strong> @fb.AdminReply</div>
                }
                <form method="post" asp-action="ReplyFeedback" class="d-flex gap-2 align-items-end mt-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@fb.Id" />
                    <textarea name="reply" class="form-control form-control-sm" rows="2" placeholder="Reply…" style="min-width:300px">@fb.AdminReply</textarea>
                    <select name="status" class="form-select form-select-sm" style="width:120px">
                        <option value="Open" selected="@(fb.Status=="Open")">Open</option>
                        <option value="In Progress" selected="@(fb.Status=="In Progress")">In Progress</option>
                        <option value="Closed" selected="@(fb.Status=="Closed")">Closed</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-send me-1"></i>Reply</button>
                </form>
            </div>
        }
    </div>
}

@* ── POPUP MANAGEMENT TAB ─────────────────────────────────── *@
@if (tab == "popups")
{
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-megaphone-fill me-2" style="color:var(--brand)"></i>Create Popup Notification</div>
        <div class="card-body">
            <form method="post" asp-action="AddPopup">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Title</label>
                        <input type="text" name="title" class="form-control" required maxlength="300" placeholder="e.g. Scheduled Maintenance" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Expires At (optional)</label>
                        <input type="datetime-local" name="expiresAt" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Message Body</label>
                        <textarea name="body" class="form-control" rows="4" required placeholder="Notification message visible to all users…"></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-run"><i class="bi bi-megaphone me-1"></i>Post Notification</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><i class="bi bi-list-ul me-2" style="color:var(--brand)"></i>All Notifications (@Model.Popups.Count)</div>
        @if (!Model.Popups.Any())
        {
            <div class="card-body text-center text-muted">No notifications posted yet.</div>
        }
        @foreach (var p in Model.Popups)
        {
            <div style="padding:1rem;border-bottom:1px solid var(--border)">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div style="flex:1">
                        <strong>@p.Title</strong>
                        @if (p.IsActive)
                        { <span class="op-chip allowed ms-2">Active</span> }
                        else
                        { <span class="op-chip ms-2" style="opacity:0.5">Inactive</span> }
                        <div style="font-size:0.75rem;color:var(--muted)">
                            Posted by @p.CreatedBy · @p.CreatedAt.ToString("dd-MMM-yyyy HH:mm")
                            @if (p.ExpiresAt.HasValue) { <span> · Expires @p.ExpiresAt.Value.ToString("dd-MMM-yyyy HH:mm")</span> }
                        </div>
                        <p style="font-size:0.82rem;margin-top:4px;white-space:pre-wrap">@p.Body</p>
                    </div>
                    <div class="d-flex flex-column gap-1">
                        <form method="post" asp-action="SetPopupActive">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@p.Id" />
                            <input type="hidden" name="active" value="@(!p.IsActive ? "true" : "false")" />
                            <button type="submit" class="btn btn-sm @(p.IsActive?"btn-outline-warning":"btn-outline-success")">
                                <i class="bi @(p.IsActive?"bi-pause-fill":"bi-play-fill") me-1"></i>@(p.IsActive?"Deactivate":"Activate")
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
