@{
    ViewData["Title"] = "Feedback";
    var myFeedbacks = ViewBag.MyFeedbacks as List<OracleSqlPortal.Models.UserFeedback> ?? new();
}
<p class="page-title"><i class="bi bi-chat-dots-fill me-2" style="color:var(--brand)"></i>Send Feedback</p>
<p class="page-subtitle">Share your suggestions, report issues or ask questions</p>

@if (TempData["Success"] != null)
{ <div class="alert-success-custom mb-3"><i class="bi bi-check-circle-fill me-1"></i>@TempData["Success"]</div> }

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-pencil-fill me-2" style="color:var(--brand)"></i>New Feedback</div>
            <div class="card-body">
                <form method="post" asp-action="Submit">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <input type="text" name="subject" class="form-control" required maxlength="300" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message</label>
                        <textarea name="message" class="form-control" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-run"><i class="bi bi-send me-1"></i>Submit</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-clock-history me-2" style="color:var(--brand)"></i>My Feedback History</div>
            <div style="max-height:400px;overflow:auto">
                @if (!myFeedbacks.Any())
                { <p class="text-muted small p-3">No feedback submitted yet.</p> }
                @foreach (var fb in myFeedbacks)
                {
                    <div style="padding:0.75rem 1rem;border-bottom:1px solid var(--border)">
                        <div class="d-flex align-items-center justify-content-between mb-1">
                            <strong style="font-size:0.85rem">@fb.Subject</strong>
                            <span class="op-chip @(fb.Status=="Closed"?"allowed":"")">@fb.Status</span>
                        </div>
                        <div style="font-size:0.75rem;color:var(--muted)">@fb.CreatedAt.ToString("dd-MMM-yyyy HH:mm")</div>
                        @if (!string.IsNullOrEmpty(fb.AdminReply))
                        {
                            <div class="mt-1 p-2 rounded" style="background:var(--surface3);font-size:0.8rem">
                                <strong>Admin reply:</strong> @fb.AdminReply
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
