@{
    ViewData["Title"] = "View Object";
    var envConfigs = ViewBag.EnvConfigs as Dictionary<string, OracleSqlPortal.Models.EnvConfig>
                     ?? new Dictionary<string, OracleSqlPortal.Models.EnvConfig>();
    string? firstEnv = envConfigs.Keys.FirstOrDefault();
}

<div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <p class="page-title"><i class="bi bi-eye-fill me-2" style="color:var(--brand)"></i>View Object</p>
        <p class="page-subtitle">Search objects by LIKE pattern, select type, then lookup definition</p>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert-danger-custom mb-3"><i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error</div>
}

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Environment</label>
                <select id="envSelect" class="form-select">
                    @foreach (var e in envConfigs.Keys)
                    { <option value="@e">@(envConfigs[e].Label ?? e)</option> }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Object Type</label>
                <select id="objectTypeFilter" class="form-select">
                    <option value="ALL">All Types</option>
                    <option value="TABLE">Table</option>
                    <option value="VIEW">View</option>
                    <option value="PROCEDURE">Stored Procedure</option>
                    <option value="FUNCTION">Function</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Object Name (LIKE pattern)</label>
                <div class="input-group">
                    <input type="text" id="objectNameInput" class="form-control"
                           placeholder="e.g. GET_USER or USER%" />
                    <button class="btn btn-outline-secondary" type="button" onclick="searchObjects()">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                </div>
            </div>
            <div class="col-md-3" id="objectSelectWrap" style="display:none">
                <label class="form-label">Matching Objects</label>
                <select id="objectSelectList" class="form-select"></select>
            </div>
        </div>
        <div class="mt-3">
            <button class="btn btn-run" onclick="lookupObject()">
                <i class="bi bi-search me-1"></i>Lookup Object
            </button>
            <span id="searchSpinner" class="ms-2" style="display:none">
                <span class="spinner-border spinner-border-sm text-secondary"></span>
            </span>
        </div>
    </div>
</div>

@if (ViewBag.Found == true)
{
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center justify-content-between">
            <span>
                <i class="bi bi-file-code-fill me-2" style="color:var(--brand)"></i>
                <strong>@ViewBag.ObjectName</strong>
                <span class="op-chip allowed ms-2">@ViewBag.ObjectType</span>
                <span class="op-chip allowed ms-1" style="background:rgba(56,189,248,0.15);color:#38bdf8">@ViewBag.Env</span>
            </span>
            <button class="btn btn-outline-secondary btn-sm" onclick="copyDefinition()">
                <i class="bi bi-clipboard me-1"></i>Copy
            </button>
        </div>
        <div style="position:relative">
            <pre id="sqlDefinition" style="margin:0;padding:1rem 1.25rem;background:var(--code-bg);color:var(--code-text);font-family:'JetBrains Mono',Consolas,monospace;font-size:0.82rem;line-height:1.7;overflow:auto;max-height:600px;white-space:pre-wrap;word-break:break-all">@ViewBag.SqlText</pre>
        </div>
    </div>

    <!-- SP Execute panel -->
    @if (ViewBag.ObjectType?.ToString() is "PROCEDURE" or "FUNCTION")
    {
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-play-circle-fill me-2" style="color:var(--brand)"></i>Execute SP / Function
            </div>
            <div class="card-body">
                <button class="btn btn-outline-primary btn-sm mb-3" onclick="loadSpParams()">
                    <i class="bi bi-gear me-1"></i>Load Parameters
                </button>
                <div id="spParamsContainer"></div>
                <div id="spOutput" class="mt-2"></div>
            </div>
        </div>
    }
}

@section Scripts {
<script>
var currentObjectName = '@ViewBag.ObjectName';
var currentObjectType = '@ViewBag.ObjectType';
var currentEnv = '@ViewBag.Env';

function searchObjects() {
    var pattern = document.getElementById('objectNameInput').value.trim();
    var objType  = document.getElementById('objectTypeFilter').value;
    var env      = document.getElementById('envSelect').value;
    if (!pattern) { alert('Please enter a search pattern.'); return; }

    document.getElementById('searchSpinner').style.display = '';
    document.getElementById('objectSelectWrap').style.display = 'none';

    fetch('@Url.Action("SearchObjects","ViewSp")', {
        method: 'POST',
        headers: {'Content-Type':'application/x-www-form-urlencoded',
                  'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value || ''},
        body: 'pattern='+encodeURIComponent(pattern)+'&objectType='+encodeURIComponent(objType)+'&env='+encodeURIComponent(env)
    })
    .then(r=>r.json())
    .then(function(data){
        document.getElementById('searchSpinner').style.display = 'none';
        if (!data.ok) { alert(data.error); return; }
        var sel = document.getElementById('objectSelectList');
        sel.innerHTML = '';
        if (!data.objects || data.objects.length === 0) {
            alert('No matching objects found.'); return;
        }
        data.objects.forEach(function(o){
            var opt = document.createElement('option');
            opt.value = o; opt.textContent = o;
            sel.appendChild(opt);
        });
        document.getElementById('objectSelectWrap').style.display = '';
        // Auto-fill if single match
        if (data.objects.length === 1)
            document.getElementById('objectNameInput').value = data.objects[0];
    })
    .catch(function(e){ document.getElementById('searchSpinner').style.display='none'; alert(e); });
}

function lookupObject() {
    var selWrap = document.getElementById('objectSelectWrap');
    var objName;
    if (selWrap.style.display !== 'none') {
        objName = document.getElementById('objectSelectList').value;
    } else {
        objName = document.getElementById('objectNameInput').value.trim();
    }
    if (!objName) { alert('Please enter or select an object name.'); return; }
    var env     = document.getElementById('envSelect').value;
    var objType = document.getElementById('objectTypeFilter').value;

    // Submit via form POST
    var form = document.createElement('form');
    form.method = 'post';
    form.action = '@Url.Action("Lookup","ViewSp")';
    var addField = function(n,v){ var i=document.createElement('input'); i.type='hidden'; i.name=n; i.value=v; form.appendChild(i); };
    addField('objectName', objName);
    addField('env', env);
    addField('objectType', objType);
    // AntiForgery
    var token = document.querySelector('[name=__RequestVerificationToken]');
    if (token) addField('__RequestVerificationToken', token.value);
    document.body.appendChild(form);
    form.submit();
}

function copyDefinition() {
    var txt = document.getElementById('sqlDefinition').textContent;
    navigator.clipboard.writeText(txt).then(function(){
        var btn = event.currentTarget;
        btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Copied!';
        setTimeout(function(){ btn.innerHTML = '<i class="bi bi-clipboard me-1"></i>Copy'; }, 2000);
    });
}

// SP Execute
function loadSpParams() {
    var spName = currentObjectName || document.getElementById('objectNameInput').value.trim();
    var env    = currentEnv || document.getElementById('envSelect').value;
    fetch('@Url.Action("GetSpParams","ViewSp")', {
        method: 'POST',
        headers: {'Content-Type':'application/x-www-form-urlencoded',
                  'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value || ''},
        body: 'spName='+encodeURIComponent(spName)+'&env='+encodeURIComponent(env)
    })
    .then(r=>r.json())
    .then(function(data){
        var container = document.getElementById('spParamsContainer');
        container.innerHTML = '';
        if (!data.ok || !data.parameters.length) {
            container.innerHTML = '<p class="text-muted small">No parameters found for this object.</p>';
            return;
        }
        data.parameters.forEach(function(p){
            var div = document.createElement('div');
            div.className = 'mb-2 d-flex gap-2 align-items-center';
            div.innerHTML = '<label class="form-label mb-0" style="min-width:160px;font-size:0.8rem">'
                +p.name+' <span class="op-chip allowed" style="font-size:0.6rem">'+p.inOut+'</span> '
                +'<span style="color:var(--muted);font-size:0.7rem">'+p.type+'</span></label>'
                +(p.inOut==='OUT' ? '<input class="form-control form-control-sm" readonly placeholder="(output)" data-pname="'+p.name+'" data-pdir="OUT">'
                : '<input class="form-control form-control-sm" placeholder="Enter value" data-pname="'+p.name+'" data-pdir="'+p.inOut+'" data-ptype="'+p.type+'">');
            container.appendChild(div);
        });
        var execBtn = document.createElement('button');
        execBtn.className = 'btn btn-run btn-sm mt-2';
        execBtn.innerHTML = '<i class="bi bi-play-fill me-1"></i>Execute';
        execBtn.onclick = executeSp;
        container.appendChild(execBtn);
    });
}

function executeSp() {
    var spName = currentObjectName;
    var env    = currentEnv || document.getElementById('envSelect').value;
    var params = [];
    document.querySelectorAll('#spParamsContainer input').forEach(function(inp){
        params.push({ Name: inp.dataset.pname, Type: inp.dataset.ptype||'VARCHAR2',
                      Direction: inp.dataset.pdir||'IN', Value: inp.value||'' });
    });
    fetch('@Url.Action("ExecuteSp","ViewSp")', {
        method: 'POST',
        headers: {'Content-Type':'application/json',
                  'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value || ''},
        body: JSON.stringify({spName, env, parameters: params})
    })
    .then(r=>r.json())
    .then(function(data){
        var out = document.getElementById('spOutput');
        if (data.ok) {
            out.innerHTML = '<div class="alert-success-custom"><i class="bi bi-check-circle-fill me-1"></i><pre style="margin:0;white-space:pre-wrap">'
                + (data.output || '(No output parameters)') + '</pre></div>';
        } else {
            out.innerHTML = '<div class="alert-danger-custom"><i class="bi bi-exclamation-triangle-fill me-1"></i>' + data.error + '</div>';
        }
    });
}
</script>
@Html.AntiForgeryToken()
}
