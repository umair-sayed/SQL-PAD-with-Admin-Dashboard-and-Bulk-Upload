@model OracleSqlPortal.Models.ResetPasswordViewModel
@{ ViewData["Title"] = "Reset Password"; Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Oracle SQL Portal — Reset Password</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="auth-page">
<div class="auth-wrap">
    <div class="auth-brand">
        <div><span class="brand-icon-lg" style="background:#22c55e"><i class="bi bi-shield-lock-fill"></i></span></div>
        <h1>Set New Password</h1><p>Choose a strong password</p>
    </div>
    <div class="auth-card">
        @if (!string.IsNullOrEmpty(Model.Error))   { <div class="auth-alert danger"><i class="bi bi-exclamation-triangle-fill"></i>@Model.Error</div> }
        @if (!string.IsNullOrEmpty(Model.Success)) { <div class="auth-alert success"><i class="bi bi-check-circle-fill"></i>@Model.Success</div> }
        @if (string.IsNullOrEmpty(Model.Success))
        {
        <form method="post" asp-action="ResetPassword">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Token" value="@Model.Token" />
            <div class="mb-3">
                <label class="form-label">New Password</label>
                <input type="password" name="Password" class="form-control" placeholder="••••••••" required autofocus />
            </div>
            <div class="mb-4">
                <label class="form-label">Confirm Password</label>
                <input type="password" name="Confirm" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn-auth-submit"><i class="bi bi-check-circle me-2"></i>Reset Password</button>
        </form>
        }
        <div class="auth-links"><a asp-controller="Auth" asp-action="Login"><i class="bi bi-arrow-left me-1"></i>Back to Sign In</a></div>
    </div>
</div>
</body></html>
