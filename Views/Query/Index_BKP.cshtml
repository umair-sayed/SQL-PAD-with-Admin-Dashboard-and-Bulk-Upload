@model OracleSqlPortal.Models.QueryViewModel
@{
    ViewData["Title"] = "SQL Editor";
    var envConfigs   = ViewBag.EnvConfigs  as Dictionary<string, OracleSqlPortal.Models.EnvConfig>
                       ?? new Dictionary<string, OracleSqlPortal.Models.EnvConfig>();
    var userPerms    = ViewBag.UserPerms   as Dictionary<string, List<string>>
                       ?? new Dictionary<string, List<string>>();
    bool isAdmin     = ViewBag.IsAdminUser == true;
    string accessMsg = ViewBag.AccessSuccess as string ?? "";
    string selectedEnv = Model.SelectedEnv ?? envConfigs.Keys.FirstOrDefault() ?? "";
    bool versionExpired = ViewBag.VersionExpired == true;

    string EnvColor(string k) => k.ToUpper() switch {
        "SIT" => "#38bdf8","UAT" => "#c084fc","PROD" => "#f97316",_ => "#22c55e" };
}

@if (versionExpired)
{
<div class="alert alert-danger d-flex align-items-center gap-2 mb-3" role="alert">
    <i class="bi bi-shield-lock-fill fs-5"></i>
    <div>
        <strong>QueryPad Expired</strong> — Version @ViewBag.VersionNumber expired on @ViewBag.ExpiryDate.
        A new build is to be updated in QueryPad. Kindly contact admin.
    </div>
</div>
}

<div class="d-flex align-items-start justify-content-between mb-2 flex-wrap gap-2">
    <div>
        <p class="page-title"><i class="bi bi-terminal-fill me-2" style="color:var(--brand)"></i>SQL Editor</p>
        <p class="page-subtitle">Execute Oracle SQL — multi-tab sessions, commit/rollback, multi-statement DML</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" onclick="addTab()" title="New Tab"><i class="bi bi-plus-lg me-1"></i>New Tab</button>
        <button class="btn btn-outline-secondary btn-sm" onclick="duplicateTab()" title="Duplicate Tab"><i class="bi bi-copy me-1"></i>Duplicate</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(accessMsg))
{ <div class="alert-success-custom mb-3"><i class="bi bi-check-circle-fill"></i> @accessMsg</div> }

<!-- ── Tab bar ── -->
<div id="tabBar" style="display:flex;gap:4px;margin-bottom:-1px;flex-wrap:wrap"></div>

<form method="post" asp-action="Run" id="mainForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="SelectedEnv" id="hiddenEnv" value="@selectedEnv" />
    <input type="hidden" name="Sql" id="hiddenSql" />

    <!-- ── Environment selector + permission chips ── -->
    <div class="card mb-3" style="border-top-left-radius:0">
        <div class="card-body" style="padding:0.75rem 1rem">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div style="min-width:180px">
                    <label class="form-label">Environment</label>
                    <select id="envSelect" class="form-select" onchange="onEnvChange(this.value)">
                        @foreach (var e in envConfigs.Keys)
                        {
                            <option value="@e" selected="@(e == selectedEnv)">@(envConfigs[e].Label ?? e)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Your Permissions</label>
                    <div id="permChips" class="d-flex flex-wrap gap-1">
                        @{
                            var currentPerms = userPerms.TryGetValue(selectedEnv, out var cp) ? cp : new List<string>();
                        }
                        @foreach (var op in OracleSqlPortal.Models.SqlOps.All)
                        {
                            bool has = currentPerms.Contains(op, StringComparer.OrdinalIgnoreCase);
                            @if (has || isAdmin)
                            {
                                <span class="op-chip @(has||isAdmin?"allowed":"denied")" style="font-size:0.65rem">@op</span>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── SQL Editor (tab content) ── -->
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
            <span><i class="bi bi-code-slash me-2" style="color:var(--brand)"></i>SQL Statement</span>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="clearEditor()" title="Clear">
                    <i class="bi bi-eraser me-1"></i>Clear
                </button>
                <!-- Commit/Rollback: enabled only for DML -->
                <button type="button" class="btn btn-outline-success btn-sm" id="commitBtn" onclick="runWithAction('commit')" disabled title="Commit (DML only)">
                    <i class="bi bi-check2-circle me-1"></i>Commit
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm" id="rollbackBtn" onclick="runWithAction('rollback')" disabled title="Rollback (DML only)">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Rollback
                </button>
                <button type="submit" class="btn btn-run" id="runBtn" @(versionExpired ? "disabled" : "")>
                    <i class="bi bi-play-fill me-1"></i>Run
                </button>
            </div>
        </div>
        <div style="position:relative">
            <textarea id="sqlEditor" class="sql-textarea form-control"
                      spellcheck="false" autocorrect="off" autocapitalize="off"
                      placeholder="SELECT * FROM my_table WHERE rownum <= 100"
                      style="width:100%;min-height:280px;height:auto;border-radius:0 !important;border:none !important;border-bottom:1px solid var(--border) !important;resize:vertical;padding:1rem 1.25rem;font-family:'JetBrains Mono',Consolas,monospace;font-size:0.84rem;line-height:1.7;background:var(--code-bg) !important;color:var(--code-text) !important;box-shadow:none !important;tab-size:4">@Model.Sql</textarea>
        </div>
        <div style="background:var(--surface3);border-top:1px solid var(--border);padding:0.4rem 1rem;font-size:0.7rem;color:var(--muted);display:flex;align-items:center;gap:1rem">
            <span id="lineCount">Lines: 1</span>
            <span id="charCount">Characters: 0</span>
            <span id="opDetected" style="color:var(--brand);font-weight:600"></span>
            <span style="margin-left:auto;opacity:0.6"><kbd style="background:var(--surface4);padding:1px 5px;border-radius:3px;font-size:0.65rem">Ctrl+Enter</kbd> to run</span>
        </div>
    </div>

    <!-- ── Result / Message ── -->
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="@(Model.IsError ? "alert-danger-custom" : "alert-success-custom") mb-3">
            <i class="bi @(Model.IsError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
            @Model.Message
            @if (!Model.IsError && Model.ElapsedMs > 0)
            {
                <span style="margin-left:auto;font-size:0.72rem;color:var(--muted)">@Model.ElapsedMs ms</span>
            }
        </div>
    }

    @if (Model.Result != null && Model.Result.Rows.Count > 0)
    {
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                <span><i class="bi bi-table me-2" style="color:var(--brand)"></i>Results</span>
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <button type="button" class="btn btn-outline-success btn-sm" onclick="exportToExcel()" title="Export to Excel">
                        <i class="bi bi-file-earmark-excel me-1"></i>Export
                    </button>
                    <span class="stat-pill"><i class="bi bi-list-ol"></i>@Model.RowCount rows</span>
                    <span class="stat-pill"><i class="bi bi-stopwatch"></i>@Model.ElapsedMs ms</span>
                    <input type="text" id="resultSearch" class="form-control form-control-sm"
                           style="width:200px" placeholder="Filter results…" oninput="filterResults(this.value)" />
                </div>
            </div>
            <div id="resultTableWrap" class="result-table-wrap" style="max-height:520px;overflow:auto">
                <table class="result-table" id="resultTable">
                    <thead>
                        <tr>
                            @foreach (System.Data.DataColumn col in Model.Result.Columns)
                            { <th>@col.ColumnName</th> }
                        </tr>
                    </thead>
                    <tbody id="resultBody">
                        @foreach (System.Data.DataRow row in Model.Result.Rows)
                        {
                            <tr>
                                @foreach (var cell in row.ItemArray)
                                { <td title="@cell">@(cell?.ToString() ?? "")</td> }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- Pagination for large tables -->
            <div id="paginationBar" class="d-flex gap-2 align-items-center p-2" style="font-size:0.78rem;color:var(--muted)"></div>
        </div>
    }
</form>

@section Scripts {
<script>
// ═══════════════════════════════════════════════════════════
// MULTI-TAB SESSION
// ═══════════════════════════════════════════════════════════
var tabs = [];
var activeTab = 0;

function loadTabsFromStorage() {
    try {
        var stored = sessionStorage.getItem('sqlTabs');
        if (stored) tabs = JSON.parse(stored);
    } catch(e){}
    if (!tabs.length) tabs = [{id:0, label:'Tab 1', sql:'@Html.Raw(Model.Sql?.Replace("'", "\\'").Replace("\n","\\n").Replace("\r","") ?? "")', env:'@selectedEnv'}];
    renderTabBar();
    loadTab(activeTab);
}

function saveTabs() {
    try { sessionStorage.setItem('sqlTabs', JSON.stringify(tabs)); } catch(e){}
}

function renderTabBar() {
    var bar = document.getElementById('tabBar');
    bar.innerHTML = '';
    tabs.forEach(function(t, i) {
        var div = document.createElement('div');
        div.style.cssText = 'display:flex;align-items:center;gap:4px;padding:4px 10px;border-radius:6px 6px 0 0;cursor:pointer;font-size:0.78rem;border:1px solid var(--border);border-bottom:'+(i===activeTab?'1px solid var(--surface2)':'1px solid var(--border)')+';background:'+(i===activeTab?'var(--surface2)':'var(--surface3)')+';';
        div.innerHTML = '<span onclick="switchTab('+i+')" style="outline:none">'+escapeHtml(t.label)+'</span>'
            +(tabs.length>1?'<button onclick="closeTab('+i+')" style="background:none;border:none;color:var(--muted);padding:0 0 0 4px;cursor:pointer;font-size:0.7rem" title="Close">✕</button>':'');
        bar.appendChild(div);
    });
}

function escapeHtml(s){ var d=document.createElement('div'); d.textContent=s; return d.innerHTML; }

function switchTab(i) {
    // Save current tab
    tabs[activeTab].sql = document.getElementById('sqlEditor').value;
    tabs[activeTab].env = document.getElementById('envSelect').value;
    activeTab = i;
    loadTab(i);
    renderTabBar();
}

function loadTab(i) {
    var t = tabs[i];
    document.getElementById('sqlEditor').value = t.sql || '';
    var sel = document.getElementById('envSelect');
    if (t.env) sel.value = t.env;
    updateCounts();
    onEnvChange(sel.value);
}

function addTab() {
    tabs[activeTab].sql = document.getElementById('sqlEditor').value;
    tabs[activeTab].env = document.getElementById('envSelect').value;
    var newId = Date.now();
    tabs.push({id:newId, label:'Tab '+(tabs.length+1), sql:'', env:document.getElementById('envSelect').value});
    activeTab = tabs.length - 1;
    renderTabBar();
    loadTab(activeTab);
    saveTabs();
}

function duplicateTab() {
    var cur = tabs[activeTab];
    tabs[cur.id] = cur.sql;  // ensure sync
    cur.sql = document.getElementById('sqlEditor').value;
    cur.env = document.getElementById('envSelect').value;
    var clone = {id: Date.now(), label: cur.label+' (copy)', sql: cur.sql, env: cur.env};
    tabs.splice(activeTab+1, 0, clone);
    activeTab = activeTab + 1;
    renderTabBar();
    loadTab(activeTab);
    saveTabs();
}

function closeTab(i) {
    if (tabs.length === 1) return;
    tabs.splice(i, 1);
    if (activeTab >= tabs.length) activeTab = tabs.length - 1;
    renderTabBar();
    loadTab(activeTab);
    saveTabs();
}

// ═══════════════════════════════════════════════════════════
// COMMIT / ROLLBACK BUTTONS
// ═══════════════════════════════════════════════════════════
var DML_OPS = ['INSERT','UPDATE','DELETE','TRUNCATE'];
function isDml(sql) {
    var s = sql.trim().toUpperCase();
    return DML_OPS.some(function(op){ return s.startsWith(op); });
}
function updateDmlButtons() {
    var sql = document.getElementById('sqlEditor').value;
    var dml = isDml(sql);
    document.getElementById('commitBtn').disabled = !dml;
    document.getElementById('rollbackBtn').disabled = !dml;

    var ops = ['SELECT','INSERT','UPDATE','DELETE','TRUNCATE','CREATE','DROP','ALTER','BEGIN','EXEC'];
    var upper = sql.trim().toUpperCase();
    var detected = ops.find(function(o){ return upper.startsWith(o); });
    document.getElementById('opDetected').textContent = detected ? ('Detected: '+detected) : '';
}

function runWithAction(action) {
    // For now we append a comment so server knows — server handles COMMIT/ROLLBACK
    var sql = document.getElementById('sqlEditor').value;
    document.getElementById('hiddenSql').value = sql + '\n--ACTION:' + action.toUpperCase();
    document.getElementById('hiddenEnv').value = document.getElementById('envSelect').value;
    document.getElementById('mainForm').submit();
}

// ═══════════════════════════════════════════════════════════
// FORM SUBMIT
// ═══════════════════════════════════════════════════════════
document.getElementById('mainForm').addEventListener('submit', function(e) {
    if (e.submitter && e.submitter.id === 'runBtn') {
        document.getElementById('hiddenSql').value = document.getElementById('sqlEditor').value;
        document.getElementById('hiddenEnv').value = document.getElementById('envSelect').value;
    }
    // Save tabs before submit
    tabs[activeTab].sql = document.getElementById('sqlEditor').value;
    tabs[activeTab].env = document.getElementById('envSelect').value;
    saveTabs();

    var btn = document.getElementById('runBtn');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Running…';
    btn.disabled = true;
});

// Ctrl+Enter
document.getElementById('sqlEditor').addEventListener('keydown', function(e) {
    if (e.ctrlKey && e.key === 'Enter') { e.preventDefault(); document.getElementById('runBtn').click(); }
    if (e.key === 'Tab') {
        e.preventDefault();
        var start = this.selectionStart, end = this.selectionEnd;
        this.value = this.value.substring(0, start) + '    ' + this.value.substring(end);
        this.selectionStart = this.selectionEnd = start + 4;
        updateCounts();
    }
});

var editor = document.getElementById('sqlEditor');
function updateCounts() {
    var v = editor.value;
    document.getElementById('lineCount').textContent   = 'Lines: '      + (v.split('\n').length);
    document.getElementById('charCount').textContent   = 'Characters: ' + v.length;
    updateDmlButtons();
}
editor.addEventListener('input', updateCounts);
updateCounts();

function clearEditor() {
    document.getElementById('sqlEditor').value = '';
    updateCounts();
}

// ═══════════════════════════════════════════════════════════
// PERMISSION CHIPS
// ═══════════════════════════════════════════════════════════
var allPerms = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(userPerms));
var allOps   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(OracleSqlPortal.Models.SqlOps.All));
var isAdmin  = @(isAdmin ? "true" : "false");

function onEnvChange(env) {
    document.getElementById('hiddenEnv').value = env;
    updatePermChips(env);
}

function updatePermChips(env) {
    var chips = document.getElementById('permChips');
    chips.innerHTML = '';
    var perms = allPerms[env] || [];
    allOps.forEach(function(op) {
        var has = isAdmin || perms.indexOf(op) >= 0;
        if (has) {
            var span = document.createElement('span');
            span.className = 'op-chip allowed';
            span.style.fontSize = '0.65rem';
            span.textContent = op;
            chips.appendChild(span);
        }
    });
}

// ═══════════════════════════════════════════════════════════
// LARGE TABLE: CLIENT-SIDE PAGINATION
// ═══════════════════════════════════════════════════════════
(function(){
    var PAGE_SIZE = 200;
    var tbody = document.getElementById('resultBody');
    var pagBar = document.getElementById('paginationBar');
    if (!tbody || !pagBar) return;
    var allRows = Array.from(tbody.querySelectorAll('tr'));
    if (allRows.length <= PAGE_SIZE) return;
    var page = 0;
    var totalPages = Math.ceil(allRows.length / PAGE_SIZE);

    function showPage(p) {
        page = p;
        allRows.forEach(function(r,i){
            r.style.display = (i >= p*PAGE_SIZE && i < (p+1)*PAGE_SIZE) ? '' : 'none';
        });
        renderPagination();
    }
    function renderPagination(){
        pagBar.innerHTML = '';
        function btn(label, p, disabled){
            var b = document.createElement('button');
            b.className = 'btn btn-outline-secondary btn-sm';
            b.textContent = label;
            b.disabled = disabled;
            b.onclick = function(){ showPage(p); };
            return b;
        }
        pagBar.appendChild(btn('« First', 0, page===0));
        pagBar.appendChild(btn('‹ Prev', page-1, page===0));
        var info = document.createElement('span');
        info.textContent = 'Page '+(page+1)+' of '+totalPages+' ('+allRows.length+' rows)';
        pagBar.appendChild(info);
        pagBar.appendChild(btn('Next ›', page+1, page===totalPages-1));
        pagBar.appendChild(btn('Last »', totalPages-1, page===totalPages-1));
    }
    showPage(0);
})();

// ═══════════════════════════════════════════════════════════
// FILTER & EXPORT
// ═══════════════════════════════════════════════════════════
function filterResults(q) {
    q = q.toLowerCase();
    document.querySelectorAll('#resultTable tbody tr').forEach(function(tr) {
        tr.style.display = (!q || tr.textContent.toLowerCase().includes(q)) ? '' : 'none';
    });
}

function exportToExcel() {
    var sql = document.getElementById('sqlEditor').value;
    var env = document.getElementById('envSelect').value;
    if (!sql.trim()) { alert("Please enter a query to export."); return; }
    var exportUrl = '@Url.Action("Excel", "Export")'
        + '?sql=' + encodeURIComponent(sql) + '&env=' + encodeURIComponent(env);
    window.open(exportUrl, '_blank');
}

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
loadTabsFromStorage();
</script>
}
